{
  "_comment": "Standard-library / compiler-provided functions whose declarations clang already supplies (via system headers or builtins). The C emitter must NOT emit its own forward declaration for these -- a synthetic prototype only produces 'conflicting types'. Loaded into DecompileDB.header_declared_functions and consumed by from_relations.rs. Keep in sync with the #include selection map in c_pass/print.rs (collect_needed_includes): a name skipped here must have its header emitted there, or it becomes 'undeclared' instead of 'conflicting'. 'prefixes' lists name prefixes to skip (e.g. compiler intrinsics).",
  "stdio": [
    "printf", "fprintf", "sprintf", "snprintf", "puts", "putchar", "getchar",
    "fopen", "fclose", "fread", "fwrite", "fgets", "fputs", "fflush", "fseek",
    "ftell", "rewind", "sscanf", "fscanf", "perror", "remove", "rename", "tmpfile",
    "setbuf", "setvbuf", "fileno", "clearerr", "feof", "ferror", "fdopen",
    "getc", "putc", "fputc", "vsnprintf", "vfprintf", "vprintf", "vsprintf",
    "vscanf", "vsscanf", "vfscanf",
    "fseeko", "ftello", "getline", "getdelim"
  ],
  "stdio_unlocked": [
    "fwrite_unlocked", "fread_unlocked", "fputs_unlocked", "fgets_unlocked",
    "clearerr_unlocked", "feof_unlocked", "ferror_unlocked", "fileno_unlocked",
    "fputc_unlocked", "fgetc_unlocked", "getc_unlocked", "putc_unlocked"
  ],
  "stdlib": [
